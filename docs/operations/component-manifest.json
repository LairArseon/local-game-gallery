{
  "schemaVersion": "1.0",
  "bundleId": "local-game-gallery",
  "bundleName": "Local Game Gallery",
  "components": [
    {
      "id": "service",
      "displayName": "Gallery Service",
      "kind": "service",
      "selectionMode": "optional",
      "artifacts": [
        "docker/gallery-service-image",
        "baremetal/service-runtime"
      ],
      "dependsOn": [],
      "conflictsWith": []
    },
    {
      "id": "web-client",
      "displayName": "Web Client",
      "kind": "web",
      "selectionMode": "optional",
      "artifacts": [
        "dist-web-client",
        "docker/gallery-web-image"
      ],
      "dependsOn": [
        "service"
      ],
      "conflictsWith": []
    },
    {
      "id": "desktop-client",
      "displayName": "Desktop Client",
      "kind": "desktop-client",
      "selectionMode": "optional",
      "artifacts": [
        "release/standalone-client"
      ],
      "dependsOn": [
        "service"
      ],
      "conflictsWith": [
        "full-desktop-suite"
      ]
    },
    {
      "id": "f95-module",
      "displayName": "F95 Module",
      "kind": "built-in-module",
      "selectionMode": "optional",
      "artifacts": [
        "dist/modules/f95",
        "dist-web-client/modules/f95",
        "dist-standalone-client/modules/f95"
      ],
      "dependsOn": [],
      "conflictsWith": []
    },
    {
      "id": "full-desktop-suite",
      "displayName": "Full Desktop Suite",
      "kind": "desktop-suite",
      "selectionMode": "optional",
      "artifacts": [
        "release/full-desktop"
      ],
      "dependsOn": [],
      "conflictsWith": [
        "desktop-client",
        "service",
        "web-client"
      ]
    }
  ],
  "selectionRules": {
    "atLeastOne": true,
    "allowServiceFreeDesktopSuite": true,
    "allowServiceFreeDesktopClient": false,
    "allowServiceFreeWebClient": false
  },
  "defaults": {
    "development": [
      "service",
      "web-client"
    ],
    "bundleInstaller": [
      "service",
      "web-client",
      "desktop-client",
      "f95-module"
    ]
  }
}
