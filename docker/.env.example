# Copy this file to docker/.env and adjust values for your machine.
# Use forward slashes on Windows paths.

# Host folder mounted to /data in the service container.
# Stores config.json and logs.
LGG_DATA_ROOT=C:/LocalGameGallery/service-data

# Host folder mounted to /games in the service container.
# The app scans this mounted path when running in Docker.
LGG_GAMES_ROOT=C:/Games

# Host folder mounted to /metadata-mirror in the service container.
# Used by metadata mirror sync and fallback browsing in Docker mode.
LGG_METADATA_MIRROR_ROOT=C:/Games-Metadata-Mirror

# Host port that exposes the API service.
LGG_SERVICE_PUBLISHED_PORT=37995

# Container bind host (keep default unless you know why to change it).
LGG_SERVICE_HOST=0.0.0.0

# Internal service port (nginx web proxy expects 37995).
LGG_SERVICE_PORT=37995

# Internal data path inside the service container.
LGG_DATA_DIR=/data

# Runtime marker used by the app to lock Docker-managed settings.
LGG_RUNTIME_CONTEXT=docker

# Host port for the browser client container.
LGG_WEB_PORT=4173

# Browser client API base path (proxied by nginx to gallery-service).
VITE_GALLERY_SERVICE_URL=/service

# Optional for image publish scripts:
# DOCKERHUB_IMAGE=your-user/local-game-gallery-service
