FROM node:22-bookworm-slim AS build

WORKDIR /app

ARG VITE_GALLERY_SERVICE_URL=/service
ENV VITE_GALLERY_SERVICE_URL=${VITE_GALLERY_SERVICE_URL}

COPY package*.json ./
RUN npm ci

COPY apps/web-client/index.html ./apps/web-client/index.html
COPY apps/web-client/vite.config.ts ./apps/web-client/vite.config.ts
COPY apps/web-client/tsconfig.json ./apps/web-client/tsconfig.json
COPY apps/web-client/tsconfig.node.json ./apps/web-client/tsconfig.node.json
COPY apps/web-client/src ./apps/web-client/src

RUN npm run build:web-client

FROM nginx:1.27-alpine

COPY docker/nginx-web.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist-web-client /usr/share/nginx/html

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
