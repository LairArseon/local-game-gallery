{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node20",
    "moduleResolution": "Node16",
    "outDir": "../../../dist-electron",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "electron"]
  },
  "include": ["./**/*.ts", "../src/types.ts"]
}
