{
  "name": "local-game-gallery",
  "version": "0.1.0",
  "private": true,
  "description": "Local desktop gallery for browsing installed games",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:watch:electron\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "watch:electron": "tsc -p electron/tsconfig.json --watch --preserveWatchOutput",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 wait-on tcp:127.0.0.1:5173 file:dist-electron/electron/main.js && nodemon --watch dist-electron --ext js,cjs --exec electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^36.2.0",
    "nodemon": "^3.1.10",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
