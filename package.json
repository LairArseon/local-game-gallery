{
  "name": "local-game-gallery",
  "version": "2.8.0",
  "private": true,
  "author": "Lair Arseon",
  "license": "CC0-1.0",
  "description": "Local desktop gallery for browsing installed games",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:watch:electron\" \"npm:dev:electron\"",
    "dev:full-desktop": "concurrently -k \"npm:dev:renderer\" \"npm:watch:electron\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config apps/full-desktop/vite.config.ts --host 127.0.0.1",
    "dev:web-client": "vite --config apps/web-client/vite.config.ts --host 0.0.0.0 --port 4173",
    "dev:standalone-client": "concurrently -k \"npm:dev:standalone-renderer\" \"npm:watch:standalone-electron\" \"npm:dev:standalone-electron\"",
    "dev:standalone-renderer": "vite --config apps/standalone-client/vite.config.ts --host 127.0.0.1",
    "dev:web": "npm run dev:web-client",
    "dev:service": "npm run build:electron && npm run start:service",
    "dev:service:headless": "npm run build:electron && concurrently -k \"npm:watch:electron\" \"npm:dev:service:headless:run\"",
    "dev:service:headless:run": "nodemon --watch dist-electron --ext js,cjs --exec node dist-electron/electron/service-cli.js",
    "watch:electron": "tsc -p apps/full-desktop/electron/tsconfig.json --watch --preserveWatchOutput",
    "watch:standalone-electron": "tsc -p apps/standalone-client/electron/tsconfig.json --watch --preserveWatchOutput",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 wait-on tcp:127.0.0.1:5173 file:dist-electron/electron/main.js && nodemon --watch dist-electron --ext js,cjs --exec electron .",
    "dev:standalone-electron": "cross-env LGG_STANDALONE_DEV_SERVER_URL=http://127.0.0.1:5174 wait-on tcp:127.0.0.1:5174 file:dist-standalone-electron/electron/main.js && nodemon --watch dist-standalone-electron --ext js,cjs --exec electron dist-standalone-electron/electron/main.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:full-desktop": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build --config apps/full-desktop/vite.config.ts",
    "build:web-client": "vite build --config apps/web-client/vite.config.ts",
    "build:standalone-client": "npm run build:standalone-renderer && npm run build:standalone-electron",
    "build:standalone-renderer": "vite build --config apps/standalone-client/vite.config.ts",
    "build:standalone-electron": "tsc -p apps/standalone-client/electron/tsconfig.json",
    "build:electron": "tsc -p apps/full-desktop/electron/tsconfig.json",
    "build:service": "npm run build:electron",
    "start:service": "electron dist-electron/electron/service-tray.js",
    "start:service:headless": "node dist-electron/electron/service-cli.js",
    "start:web-client": "electron dist-electron/electron/web-client-tray.js",
    "up:baremetal": "node scripts/up-baremetal.mjs",
    "up:baremetal:dev": "node scripts/up-baremetal.mjs --dev",
    "up:baremetal:stack": "concurrently \"npm:start:service\" \"npm:start:web-client\" \"npm:start:standalone-client\"",
    "up:baremetal:stack:dev": "cross-env LGG_DEBUG_VIRTUALIZATION=1 concurrently \"npm:start:service\" \"npm:start:web-client\" \"npm:start:standalone-client\"",
    "down:baremetal": "node scripts/down-baremetal.mjs",
    "unlock:install-folder": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-install-locks.ps1",
    "compose:up": "docker compose --env-file docker/.env -f docker/compose.yml up --build",
    "compose:down": "docker compose --env-file docker/.env -f docker/compose.yml down",
    "docker:image:service": "node scripts/dockerhub-image.mjs",
    "docker:image:service:push": "node scripts/dockerhub-image.mjs --push",
    "build:icon": "node scripts/build-icon.mjs",
    "preview": "vite preview --config apps/full-desktop/vite.config.ts",
    "preview:web-client": "vite preview --config apps/web-client/vite.config.ts --port 4173 --strictPort",
    "preview:standalone-client": "vite preview --config apps/standalone-client/vite.config.ts --port 4174 --strictPort",
    "start": "electron .",
    "start:full-desktop": "electron .",
    "start:standalone-client": "electron dist-standalone-electron/electron/main.js",
    "pack:win": "npm run build && npm run build:icon && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --dir",
    "dist:win": "npm run build && npm run build:icon && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis && node scripts/prune-installer-artifacts.mjs --target full",
    "dist:bundle-installer:win": "npm run build:electron && npm run build:web-client && npm run build:standalone-client && npm run build:icon && node scripts/build-bundle-installer.mjs && node scripts/prune-installer-artifacts.mjs --target bundle",
    "pack:standalone-client:win": "npm run build:standalone-client && npm run build:icon && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --config apps/standalone-client/builder.json --win --dir",
    "dist:standalone-client:win": "npm run build:standalone-client && npm run build:icon && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --config apps/standalone-client/builder.json --win nsis && node scripts/prune-installer-artifacts.mjs --target standalone",
    "dist:all:win": "node scripts/package-all.mjs"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "i18next": "^26.0.4",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.2",
    "sharp": "^0.34.5",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.10",
    "png-to-ico": "^2.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.localgamegallery.app",
    "productName": "Local Game Gallery",
    "asar": true,
    "directories": {
      "output": "release/full-desktop"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": true,
      "icon": "icon/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Local Game Gallery",
      "installerIcon": "icon/icon.ico",
      "uninstallerIcon": "icon/icon.ico",
      "installerHeaderIcon": "icon/icon.ico"
    }
  }
}
