{
  "name": "local-game-gallery",
  "version": "0.1.1",
  "private": true,
  "description": "Local desktop gallery for browsing installed games",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:watch:electron\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "watch:electron": "tsc -p electron/tsconfig.json --watch --preserveWatchOutput",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 wait-on tcp:127.0.0.1:5173 file:dist-electron/electron/main.js && nodemon --watch dist-electron --ext js,cjs --exec electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:icon": "node scripts/build-icon.mjs",
    "preview": "vite preview",
    "start": "electron .",
    "pack:win": "npm run build && npm run build:icon && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --dir",
    "dist:win": "npm run build && npm run build:icon && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis"
  },
  "dependencies": {
    "i18next": "^26.0.4",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.10",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.localgamegallery.app",
    "productName": "Local Game Gallery",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": true,
      "icon": "icon/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Local Game Gallery",
      "installerIcon": "icon/icon.ico",
      "uninstallerIcon": "icon/icon.ico",
      "installerHeaderIcon": "icon/icon.ico"
    }
  }
}
